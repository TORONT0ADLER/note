{
  "name": "noteforge",
  "version": "1.0.0",
  "description": "Desktop notes app built with Nuxt and Electron",
  "author": "Ilya",
  "private": true,
  "type": "commonjs",
  "main": "electron/main.js",
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "dev": "nuxt dev",
    "build": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "lint": "eslint .",
    "typecheck": "nuxt typecheck",
    "electron": "electron .",
    "electron:dev": "concurrently \"pnpm dev\" \"wait-on http://localhost:3000 && electron .\"",
    "dist": "pnpm build && electron-builder",
    "dist:win": "pnpm build && electron-builder --win nsis --x64"
  },
  "build": {
    "appId": "com.note.app",
    "productName": "NoteForge",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      ".output/**/*",
      "electron/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis"
    }
  },
  "dependencies": {
    "@iconify-json/lucide": "^1.2.98",
    "@iconify-json/simple-icons": "^1.2.74",
    "@nuxt/ui": "^4.5.1",
    "@tiptap/extension-code-block-lowlight": "^3.20.4",
    "@tiptap/extension-link": "^3.20.4",
    "@tiptap/extension-placeholder": "^3.20.4",
    "@tiptap/extension-table": "^3.20.4",
    "@tiptap/extension-table-cell": "^3.20.4",
    "@tiptap/extension-table-header": "^3.20.4",
    "@tiptap/extension-table-row": "^3.20.4",
    "@tiptap/extension-underline": "^3.20.4",
    "@tiptap/starter-kit": "^3.20.4",
    "@tiptap/vue-3": "^3.20.4",
    "highlight.js": "^11.11.1",
    "lowlight": "^3.3.0",
    "nuxt": "^4.4.2",
    "serve-handler": "^6.1.7",
    "tailwindcss": "^4.2.1"
  },
  "devDependencies": {
    "@nuxt/eslint": "^1.15.2",
    "concurrently": "^9.2.1",
    "electron": "^41.0.4",
    "electron-builder": "^26.8.1",
    "eslint": "^10.0.3",
    "typescript": "^5.9.3",
    "vue-tsc": "^3.2.5",
    "wait-on": "^9.0.4"
  }
}
